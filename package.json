{
  "name": "fileclrk",
  "displayName": "FileClrk",
  "description": "A series of file utilities for code-based browsers",
  "publisher": "yft",
  "repository": {
    "type": "git",
    "url": "https://github.com/toumorokoshi/code-fileclrk"
  },
  "version": "0.0.2",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "fileclrk.createFile",
        "title": "FileClrk: Create File"
      },
      {
        "command": "fileclrk.copyRelativePath",
        "title": "FileClrk: Copy Relative Path"
      },
      {
        "command": "fileclrk.deleteFile",
        "title": "FileClrk: Delete File"
      },
      {
        "command": "fileclrk.createFolder",
        "title": "FileClrk: Create Folder"
      },
      {
        "command": "fileclrk.renameFile",
        "title": "FileClrk: Rename File"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "node ./out/test/runTest.js",
    "package": "npx @vscode/vsce package"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "25.x",
    "@types/vscode": "^1.109.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "eslint": "^10.0.2",
    "glob": "^13.0.6",
    "globals": "^17.4.0",
    "mocha": "^11.7.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
